{
  "name": "repconnect",
  "private": true,
  "scripts": {
    "start": "turbo run start",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "server:i": "pnpm --filter @rep/server i",
    "server:remove": "pnpm --filter @rep/server remove",
    "web:i": "pnpm --filter @rep/web i",
    "web:add": "pnpm --filter @rep/web add",
    "web:remove": "pnpm --filter @rep/web remove",
    "web:dev": "cd apps/web && pnpm dev"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsx": "^4.22.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "22.22.3"
  }
}

{
  "name": "repconnect",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "server:i": "pnpm --filter @rep/server i",
    "server:remove": "pnpm --filter @rep/server remove",
    "web:i": "pnpm --filter @rep/web i",
    "web:add": "pnpm --filter @rep/web add",
    "web:remove": "pnpm --filter @rep/web remove",
    "web:dev": "cd apps/web && pnpm dev"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsx": "^4.22.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "engines": {
    "node": ">=18"
  }
}
